{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "elephpants": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "sponsor": {
                        "type": "string"
                    },
                    "year": {
                        "type": "integer"
                    },
                    "image": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "name",
                    "description",
                    "sponsor",
                    "year",
                    "prototype"
                ]
            }
        }
    },
    "required": [
        "elephpants"
    ]
}
